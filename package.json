{
  "name": "xiaoba-cli",
  "version": "1.4.6",
  "description": "CatsCo - local agent runtime and dashboard",
  "main": "electron/main.js",
  "bin": {
    "catsco": "dist/index.js",
    "xiaoba": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:cli": "node dist/index.js",
    "electron:dev": "npm run build && node scripts/start-electron-dev.mjs",
    "electron:build": "npm run build && npm run prepare:runtime && npm run prune:electron-optionals && electron-builder --config electron-builder.config.cjs --publish never",
    "electron:build:mac": "npm run build && npm run prepare:runtime && npm run prune:electron-optionals && electron-builder --config electron-builder.config.cjs --mac --publish never",
    "electron:build:win": "npm run build && npm run prepare:runtime && npm run prune:electron-optionals && electron-builder --config electron-builder.config.cjs --win --publish never",
    "electron:build:linux": "npm run build && npm run prepare:runtime && npm run prune:electron-optionals && electron-builder --config electron-builder.config.cjs --linux --publish never",
    "watch": "tsc --watch",
    "test": "node scripts/run-tests.mjs runtime",
    "test:runtime": "node scripts/run-tests.mjs runtime",
    "test:legacy": "node scripts/run-tests.mjs legacy",
    "test:all": "node scripts/run-tests.mjs all",
    "test:list": "node scripts/run-tests.mjs runtime --list",
    "report": "node dist/index.js chat --exec '/report'",
    "clean-logs": "node scripts/clean-logs.mjs",
    "prepare:runtime": "node scripts/prepare-runtime.mjs",
    "prepare:runtime:refresh": "node scripts/prepare-runtime.mjs --refresh",
    "prune:electron-optionals": "node scripts/prune-electron-optional-native.mjs",
    "electron:build:mac:x64": "npm run build && node scripts/prepare-runtime.mjs darwin x64 && npm run prune:electron-optionals && electron-builder --config electron-builder.config.cjs --mac --x64 --publish never",
    "electron:build:mac:arm64": "npm run build && node scripts/prepare-runtime.mjs darwin arm64 && npm run prune:electron-optionals && electron-builder --config electron-builder.config.cjs --mac --arm64 --publish never",
    "release:check": "node scripts/check-release-branding.mjs",
    "release:verify-version": "node scripts/verify-release-version.js",
    "skillhub:trust-root": "node scripts/update-skillhub-root-key.mjs",
    "version:sync": "node scripts/inject-version.js"
  },
  "keywords": [
    "cli",
    "ai",
    "assistant",
    "catsco",
    "xiaoba",
    "chatbot",
    "command-line",
    "typescript"
  ],
  "author": "CatCompany <cat@company.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/buildsense-ai/XiaoBa-CLI.git"
  },
  "bugs": {
    "url": "https://github.com/buildsense-ai/XiaoBa-CLI/issues"
  },
  "homepage": "https://github.com/buildsense-ai/XiaoBa-CLI#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@larksuiteoapi/node-sdk": "^1.58.0",
    "@napi-rs/canvas": "^1.0.2",
    "axios": "^1.18.1",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "deasync": "^0.1.31",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "inquirer": "^8.2.7",
    "ora": "^5.4.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.6.82",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/deasync": "^0.1.5",
    "@types/express": "^5.0.6",
    "@types/glob": "^8.1.0",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.10.5",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "js-yaml": "^4.1.0",
    "playwright": "^1.58.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.catcompany.xiaoba",
    "productName": "CatsCo",
    "icon": null,
    "directories": {
      "output": "release"
    },
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "buildsense-ai",
      "repo": "XiaoBa-CLI"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "dashboard/**/*",
      "prompts/**/*",
      "skills/**/*",
      "!skills/**/*.pyo",
      "!skills/**/*.pyc",
      "!skills/**/__pycache__/**",
      "skills/README.md",
      "THIRD_PARTY_NOTICES.md",
      "LICENSE",
      ".env.example",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "**/*.node",
          "**/*.js",
          "**/*.mjs",
          "**/*.wasm",
          "**/*.json",
          "!**/.bin/**",
          "!**/test/**",
          "!**/tests/**",
          "!**/*.md",
          "!electron/**",
          "!electron-builder/**",
          "@types/**",
          "!typescript/**"
        ]
      }
    ],
    "extraFiles": [
      {
        "from": "build-resources/runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build-resources/icons/icon.icns",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build-resources/icon.ico",
      "artifactName": "${productName}-${version}-win.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "CatsCo"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build-resources/icon.png",
      "artifactName": "${productName}-${version}-linux.${ext}"
    },
    "dmg": {
      "title": "CatsCo",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
